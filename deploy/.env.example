# agent-compose deployment configuration
#
# Copy to .env and adjust. `install.sh` creates this file automatically and
# fills in a high-entropy AUTH_SECRET on first run.

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
# Host port the web UI / API is published on.
AGENT_COMPOSE_HTTP_PORT=80

# ---------------------------------------------------------------------------
# Authentication
# On first run `install.sh` generates a random AUTH_PASSWORD and AUTH_SECRET if
# these are empty, writes them here, and prints the credentials to the terminal.
# AUTH_SECRET must be a stable, high-entropy value so sessions survive restarts.
# ---------------------------------------------------------------------------
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SECRET=
AUTH_SESSION_TTL=24h

# ---------------------------------------------------------------------------
# Container images (multi-arch; Docker selects the right arch automatically).
# Override the prefix to use a mirror or private registry.
# ---------------------------------------------------------------------------
AGENT_COMPOSE_IMAGE=ghcr.io/chaitin/agent-compose:latest
AGENT_COMPOSE_FRONTEND_IMAGE=ghcr.io/chaitin/agent-compose-frontend:latest

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
RUNTIME_DRIVER=docker
# Guest image used by the docker runtime driver.
DEFAULT_IMAGE=ghcr.io/chaitin/agent-compose-guest:latest
# Registry used when pulling guest images.
IMAGE_REGISTRY=docker.io
# Guest image for the microsandbox driver, when enabled.
MICROSANDBOX_DEFAULT_IMAGE=debian:bookworm-slim
# Host path bind-mounted into guest sessions. Defaults to <install-dir>/data/...
# DOCKER_HOST_SESSION_ROOT=

# ---------------------------------------------------------------------------
# Jupyter proxy base path (must match the frontend route).
# ---------------------------------------------------------------------------
JUPYTER_PROXY_BASE=/jupyter

# ---------------------------------------------------------------------------
# LLM (optional). Configure if your loaders/agents call an LLM.
# ---------------------------------------------------------------------------
# LLM_API_ENDPOINT=https://api.openai.com
# LLM_API_KEY=
# LLM_MODEL=
# LLM_TIMEOUT=60s
