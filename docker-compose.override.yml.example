services:
  agent-compose:
    image: ${AGENT_COMPOSE_DEV_IMAGE:-agent-compose:latest}
    build:
      context: .
      dockerfile: ${AGENT_COMPOSE_DOCKERFILE:-Dockerfile}
      args:
        VERSION: ${VERSION:-dev}
        REGISTRY_MIRROR: ${REGISTRY_MIRROR:-docker.io}
        GOPROXY: ${GOPROXY:-https://goproxy.cn,direct}
        HTTP_PROXY: ${HTTP_PROXY:-}
        HTTPS_PROXY: ${HTTPS_PROXY:-}
        ALL_PROXY: ${ALL_PROXY:-}
        NO_PROXY: ${NO_PROXY:-}
